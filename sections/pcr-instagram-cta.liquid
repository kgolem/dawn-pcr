{% comment %}
  Pacific Coast Roasters — Instagram CTA section
  Gold background, centered heading + follow button.
  Place after testimonials/social-proof on the homepage.
{% endcomment %}

<section class="pcr-instagram-cta">
  <div class="page-width pcr-instagram-cta__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="pcr-instagram-cta__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
      <a
        href="{{ section.settings.button_url }}"
        class="pcr-instagram-cta__btn"
        target="_blank"
        rel="noopener"
        aria-label="{{ section.settings.button_label }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
        </svg>
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

    {%- liquid
      assign has_embeds = false
      if section.settings.embed_1 != blank or section.settings.embed_2 != blank or section.settings.embed_3 != blank
        assign has_embeds = true
      endif
    -%}
    {%- if has_embeds -%}
      <div class="pcr-instagram-cta__videos">
        {%- for i in (1..3) -%}
          {%- liquid
            case i
              when 1
                assign embed_url = section.settings.embed_1
              when 2
                assign embed_url = section.settings.embed_2
              when 3
                assign embed_url = section.settings.embed_3
            endcase
          -%}
          {%- if embed_url != blank -%}
            {%- liquid
              assign clean_url = embed_url | split: '?' | first | strip
              assign last_char = clean_url | slice: -1, 1
              if last_char != '/'
                assign clean_url = clean_url | append: '/'
              endif
              unless clean_url contains '/embed/'
                assign clean_url = clean_url | append: 'embed/'
              endunless
            -%}
            <div class="pcr-instagram-cta__video-wrap">
              <iframe
                src="{{ clean_url }}"
                class="pcr-instagram-cta__video"
                frameborder="0"
                scrolling="no"
                allowtransparency="true"
                loading="lazy"
                title="Instagram Reel {{ i }}"
              ></iframe>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PCR Instagram CTA",
  "tag": "section",
  "class": "pcr-section-instagram-cta",
  "settings": [
    {
      "type": "header",
      "content": "Instagram embeds"
    },
    {
      "type": "text",
      "id": "embed_1",
      "label": "Reel 1 URL",
      "info": "Paste an Instagram Reel or post URL, e.g. https://www.instagram.com/reel/ABC123/"
    },
    {
      "type": "text",
      "id": "embed_2",
      "label": "Reel 2 URL"
    },
    {
      "type": "text",
      "id": "embed_3",
      "label": "Reel 3 URL"
    },
    {
      "type": "header",
      "content": "Heading & CTA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Along on Instagram"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Follow @PacificCoastRoasters"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Instagram URL"
    }
  ],
  "presets": [
    { "name": "PCR Instagram CTA" }
  ]
}
{% endschema %}
