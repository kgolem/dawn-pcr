{% comment %}
  Pacific Coast Roasters — Instagram CTA section
  Gold background, centered heading + follow button.
  Place after testimonials/social-proof on the homepage.
{% endcomment %}

<section class="pcr-instagram-cta">
  <div class="page-width pcr-instagram-cta__inner">

    {%- liquid
      assign has_videos = false
      if section.settings.video_1 != blank or section.settings.video_2 != blank or section.settings.video_3 != blank
        assign has_videos = true
      endif
    -%}
    {%- if has_videos -%}
      <div class="pcr-instagram-cta__videos">
        {%- if section.settings.video_1 != blank -%}
          <div class="pcr-instagram-cta__video-wrap">
            <video
              src="{{ section.settings.video_1 }}"
              autoplay muted loop playsinline
              preload="metadata"
              class="pcr-instagram-cta__video"
              {%- if section.settings.poster_1 != blank %}
                poster="{{ section.settings.poster_1 | image_url: width: 600 }}"
              {%- endif %}
            ></video>
          </div>
        {%- endif -%}
        {%- if section.settings.video_2 != blank -%}
          <div class="pcr-instagram-cta__video-wrap">
            <video
              src="{{ section.settings.video_2 }}"
              autoplay muted loop playsinline
              preload="metadata"
              class="pcr-instagram-cta__video"
              {%- if section.settings.poster_2 != blank %}
                poster="{{ section.settings.poster_2 | image_url: width: 600 }}"
              {%- endif %}
            ></video>
          </div>
        {%- endif -%}
        {%- if section.settings.video_3 != blank -%}
          <div class="pcr-instagram-cta__video-wrap">
            <video
              src="{{ section.settings.video_3 }}"
              autoplay muted loop playsinline
              preload="metadata"
              class="pcr-instagram-cta__video"
              {%- if section.settings.poster_3 != blank %}
                poster="{{ section.settings.poster_3 | image_url: width: 600 }}"
              {%- endif %}
            ></video>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="pcr-instagram-cta__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
      <a
        href="{{ section.settings.button_url }}"
        class="pcr-instagram-cta__btn"
        target="_blank"
        rel="noopener"
        aria-label="{{ section.settings.button_label }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
        </svg>
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PCR Instagram CTA",
  "tag": "section",
  "class": "pcr-section-instagram-cta",
  "settings": [
    {
      "type": "header",
      "content": "Vertical videos"
    },
    {
      "type": "text",
      "id": "video_1",
      "label": "Video 1 URL (MP4)",
      "info": "Upload to Content → Files, paste URL here. 9:16 vertical format."
    },
    {
      "type": "image_picker",
      "id": "poster_1",
      "label": "Video 1 poster image"
    },
    {
      "type": "text",
      "id": "video_2",
      "label": "Video 2 URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "poster_2",
      "label": "Video 2 poster image"
    },
    {
      "type": "text",
      "id": "video_3",
      "label": "Video 3 URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "poster_3",
      "label": "Video 3 poster image"
    },
    {
      "type": "header",
      "content": "Heading & CTA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Along on Instagram"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Follow @PacificCoastRoasters"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Instagram URL"
    }
  ],
  "presets": [
    { "name": "PCR Instagram CTA" }
  ]
}
{% endschema %}
