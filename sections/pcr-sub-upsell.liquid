{% comment %}
  Pacific Coast Roasters — Subscription Upsell section
  Compact banner placed below the product grid on collection pages
  to convert one-time buyers into subscribers.
{% endcomment %}

<section class="pcr-sub-upsell">
  <div class="page-width pcr-sub-upsell__inner">

    <div class="pcr-sub-upsell__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pcr-eyebrow pcr-sub-upsell__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="pcr-sub-upsell__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.description != blank -%}
        <p class="pcr-sub-upsell__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- assign perk_keys = 'perk_1,perk_2,perk_3,perk_4' | split: ',' -%}
      {%- assign has_perks = false -%}
      {%- for key in perk_keys -%}
        {%- if section.settings[key] != blank -%}{%- assign has_perks = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_perks -%}
        <ul class="pcr-sub-upsell__perks" role="list">
          {%- for key in perk_keys -%}
            {%- if section.settings[key] != blank -%}
              <li class="pcr-sub-upsell__perk">
                <span class="pcr-sub-upsell__perk-check" aria-hidden="true">✓</span>
                {{ section.settings[key] }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="pcr-sub-upsell__ctas">
        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a
            href="{{ section.settings.cta_url }}"
            class="pcr-ws-btn pcr-ws-btn--gold pcr-sub-upsell__cta-primary"
            data-analytics-event="sub_upsell_cta_click"
          >
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank and section.settings.secondary_url != blank -%}
          <a
            href="{{ section.settings.secondary_url }}"
            class="pcr-sub-upsell__cta-secondary"
          >
            {{ section.settings.secondary_label }} →
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_copy != blank -%}
        <p class="pcr-sub-upsell__trust">{{ section.settings.trust_copy }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.image != blank -%}
      <div class="pcr-sub-upsell__visual" aria-hidden="true">
        <img
          src="{{ section.settings.image | image_url: width: 600 }}"
          srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w"
          sizes="(min-width: 1024px) 340px, 100vw"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          class="pcr-sub-upsell__img"
        >
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PCR Subscription Upsell",
  "tag": "section",
  "class": "pcr-section-sub-upsell",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Subscribe & Save" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Never Run Out. Save 15% Every Order." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Turn your favorite bag into a recurring delivery. Pick your cadence, save 15% on every shipment, and manage everything from your account — no commitment required." },
    { "type": "header", "content": "Perks (checkmark bullets)" },
    { "type": "text", "id": "perk_1", "label": "Perk 1", "default": "15% off every order, forever" },
    { "type": "text", "id": "perk_2", "label": "Perk 2", "default": "Free shipping on all subscriptions" },
    { "type": "text", "id": "perk_3", "label": "Perk 3", "default": "Delivery every 2, 4, 6, or 8 weeks" },
    { "type": "text", "id": "perk_4", "label": "Perk 4", "default": "Swap, pause, or cancel anytime" },
    { "type": "header", "content": "CTAs" },
    { "type": "text", "id": "cta_label", "label": "Primary button label", "default": "Start Your Subscription" },
    { "type": "url", "id": "cta_url", "label": "Primary button URL" },
    { "type": "text", "id": "secondary_label", "label": "Secondary link label", "default": "See how it works" },
    { "type": "url", "id": "secondary_url", "label": "Secondary link URL" },
    { "type": "text", "id": "trust_copy", "label": "Trust microcopy", "default": "No commitment — manage deliveries from your account" },
    { "type": "header", "content": "Visual" },
    { "type": "image_picker", "id": "image", "label": "Optional side image", "info": "Coffee bag or lifestyle photo. Appears on the right on desktop. Leave blank for full-width copy layout." }
  ],
  "presets": [
    {
      "name": "PCR Subscription Upsell"
    }
  ]
}
{% endschema %}
