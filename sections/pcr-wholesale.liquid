{%- comment -%} ══════════════════════════════════════════
  8. FAQ
══════════════════════════════════════════ {%- endcomment -%}
<section class="pcr-ws-section pcr-ws-faq bg-white">
  <div class="page-width pcr-ws-faq__inner">
    <h2 class="pcr-ws-section__title">Frequently Asked Questions</h2>
    <div class="pcr-ws-faq__list">

      <details class="pcr-ws-faq__item">
        <summary class="pcr-ws-faq__q">What is your minimum order quantity?</summary>
        <div class="pcr-ws-faq__a">Our standard wholesale minimum is 10 lbs per week. We offer flexible terms for new businesses during their launch phase — mention it in your inquiry and we'll work something out.</div>
      </details>

      <details class="pcr-ws-faq__item">
        <summary class="pcr-ws-faq__q">What bags and sizes do you offer?</summary>
        <div class="pcr-ws-faq__a">All blends are available in 12oz (340g) and 1kg (35oz) bags. Our lineup includes Mike's Blend, Rise &amp; Gr!nd, Shadow Work, Decaf, and rotating seasonal single origins (Peaberry, Pinkerton, Tanzania, and more).</div>
      </details>

      <details class="pcr-ws-faq__item">
        <summary class="pcr-ws-faq__q">How fast do you fulfill orders?</summary>
        <div class="pcr-ws-faq__a">We roast weekly and ship within 48 hours of order confirmation from our Watsonville, CA facility. Order by Sunday night and expect delivery by Wednesday.</div>
      </details>

      <details class="pcr-ws-faq__item">
        <summary class="pcr-ws-faq__q">Do you offer private label roasting?</summary>
        <div class="pcr-ws-faq__a">Yes. We offer white-label services for grocery and high-volume accounts meeting a minimum of 50 lbs per week. Contact us for custom bagging and label options.</div>
      </details>

      <details class="pcr-ws-faq__item">
        <summary class="pcr-ws-faq__q">What are your payment terms?</summary>
        <div class="pcr-ws-faq__a">Initial orders are processed via credit card. After 30 days of consistent ordering, accounts in good standing can be transitioned to Net 15 or Net 30 terms.</div>
      </details>

      <details class="pcr-ws-faq__item">
        <summary class="pcr-ws-faq__q">Can I request samples before committing?</summary>
        <div class="pcr-ws-faq__a">Yes — mention it in your application and we'll arrange a curated sample kit suited to your equipment and brewing style. No commitment required.</div>
      </details>

    </div>
  </div>
</section>

{%- comment -%} ══════════════════════════════════════════
  9. CONTACT FORM
══════════════════════════════════════════ {%- endcomment -%}
<section id="ws-apply" class="pcr-ws-section pcr-ws-form-section bg-black">
  <div class="page-width pcr-ws-form__inner">
    <div class="pcr-ws-section__header pcr-ws-section__header--white">
      <h2 class="pcr-ws-section__title pcr-ws-section__title--white">Start Your Wholesale Partnership</h2>
      <p class="pcr-ws-form__subtitle">Fill out the details below and our team will reach out within 24 hours to arrange a tasting.</p>
    </div>

    {%- if form.posted_successfully? -%}
      <div class="pcr-ws-form__success">
        <div class="pcr-ws-form__success-icon" aria-hidden="true">✓</div>
        <h3 class="pcr-ws-form__success-title">Application Received</h3>
        <p class="pcr-ws-form__success-desc">Thank you for reaching out. We're reviewing your details and will be in touch shortly.</p>
      </div>
    {%- else -%}
      {%- form 'contact', id: 'pcr-wholesale-form' -%}
        <div class="pcr-ws-form__card">
          {%- if form.errors -%}
            <div class="pcr-ws-form__errors" role="alert">
              Please fix the following errors:
              <ul>
                {%- for field in form.errors -%}
                  <li>{{ field }} — {{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="pcr-ws-form__row">
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-first-name">First Name</label>
              <input id="ws-first-name" type="text" name="contact[first_name]" required placeholder="Jane" class="pcr-ws-form__input">
            </div>
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-last-name">Last Name</label>
              <input id="ws-last-name" type="text" name="contact[last_name]" required placeholder="Doe" class="pcr-ws-form__input">
            </div>
          </div>

          <div class="pcr-ws-form__row">
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-business">Business Name</label>
              <input id="ws-business" type="text" name="contact[business_name]" required placeholder="The Daily Press" class="pcr-ws-form__input">
            </div>
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-type">Business Type</label>
              <select id="ws-type" name="contact[business_type]" class="pcr-ws-form__select">
                <option>Cafe / Coffee Shop</option>
                <option>Restaurant / Bar</option>
                <option>Office / Workplace</option>
                <option>Hotel / Hospitality</option>
                <option>Grocery / Retail</option>
                <option>Other</option>
              </select>
            </div>
          </div>

          <div class="pcr-ws-form__row">
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-email">Email Address</label>
              <input id="ws-email" type="email" name="contact[email]" required placeholder="jane@example.com" class="pcr-ws-form__input">
            </div>
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-volume">Estimated Weekly Volume</label>
              <select id="ws-volume" name="contact[weekly_volume]" class="pcr-ws-form__select">
                <option>Just starting out (under 10 lbs)</option>
                <option>10–30 lbs / week</option>
                <option>30–100 lbs / week</option>
                <option>100+ lbs / week</option>
              </select>
            </div>
          </div>

          <div class="pcr-ws-form__field">
            <label class="pcr-ws-form__label" for="ws-message">Tell us about your needs</label>
            <textarea id="ws-message" name="contact[body]" rows="4" class="pcr-ws-form__textarea" placeholder="Do you need equipment sourcing? Looking for a specific roast profile? Let us know."></textarea>
          </div>

          <button type="submit" class="pcr-ws-btn pcr-ws-btn--submit">Submit Inquiry</button>
          <p class="pcr-ws-form__note">Need immediate help? Email us at <a href="mailto:{{ contact_email }}" class="pcr-ws-form__note-link">{{ contact_email }}</a></p>
        </div>
      {%- endform -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PCR Wholesale",
  "tag": "section",
