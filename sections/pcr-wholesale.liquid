══════════════════════════════════════════ {%- endcomment -%}
<section id="ws-products" class="pcr-ws-section pcr-ws-products bg-black">
  <div class="page-width">
    <div class="pcr-ws-products__header">
      <div>
        <h2 class="pcr-ws-section__title pcr-ws-section__title--white">Core Wholesale Offerings</h2>
        <p class="pcr-ws-products__subtitle">Our full lineup. Every coffee ships with brew recipes and dial-in parameters.</p>
      </div>
      <a href="mailto:{{ contact_email }}" class="pcr-ws-btn pcr-ws-btn--ghost">
        Request Full Catalog →
      </a>
    </div>
    <div class="pcr-ws-grid pcr-ws-grid--4">
      <div class="pcr-ws-product-card">
        <span class="pcr-ws-product-card__use">Espresso · Milk Drinks</span>
        <h3 class="pcr-ws-product-card__name">Mike's Blend</h3>
        <p class="pcr-ws-product-card__desc">Our flagship wholesale espresso. Rich dark chocolate, warm spice, and caramel sweetness. Cuts through milk perfectly — built for volume and consistency.</p>
        <div class="pcr-ws-product-card__footer">
          <span class="pcr-ws-product-card__format-label">Available formats</span>
          <span class="pcr-ws-product-card__format">12oz &amp; 1kg bags</span>
        </div>
      </div>
      <div class="pcr-ws-product-card">
        <span class="pcr-ws-product-card__use">Batch Brew · Drip</span>
        <h3 class="pcr-ws-product-card__name">Rise &amp; Gr!nd</h3>
        <p class="pcr-ws-product-card__desc">A crowd-pleasing light roast perfect for high-volume filter programs. Bright, clean, and consistent year round — a cup that works for every palate.</p>
        <div class="pcr-ws-product-card__footer">
          <span class="pcr-ws-product-card__format-label">Available formats</span>
          <span class="pcr-ws-product-card__format">12oz &amp; 1kg bags</span>
        </div>
      </div>
      <div class="pcr-ws-product-card">
        <span class="pcr-ws-product-card__use">Pour Over · Bold Drinkers</span>
        <h3 class="pcr-ws-product-card__name">Shadow Work</h3>
        <p class="pcr-ws-product-card__desc">A dark roast for those who want their coffee to mean something. Smoky, full-bodied, and complex — great as espresso or a bold drip option on your menu.</p>
        <div class="pcr-ws-product-card__footer">
          <span class="pcr-ws-product-card__format-label">Available formats</span>
          <span class="pcr-ws-product-card__format">12oz &amp; 1kg bags</span>
        </div>
      </div>
      <div class="pcr-ws-product-card">
        <span class="pcr-ws-product-card__use">Retail Shelf · Pour Over</span>
        <h3 class="pcr-ws-product-card__name">Seasonal Single Origins</h3>
        <p class="pcr-ws-product-card__desc">Rotating selections from our exotic sourcing program — Tanzanian Peaberry, Kenya Pinkerton, and more. Ideal for specialty menus and retail shelves.</p>
        <div class="pcr-ws-product-card__footer">
          <span class="pcr-ws-product-card__format-label">Available formats</span>
          <span class="pcr-ws-product-card__format">12oz bags &amp; retail 2-packs</span>
        </div>
      </div>
    </div>
  </div>
</section>

