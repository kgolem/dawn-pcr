{% comment %}
  Pacific Coast Roasters — Wholesale Page Section
  All content is editable via the Shopify theme editor.
{% endcomment %}

{%- liquid
  assign contact_email = section.settings.contact_email | default: 'wholesale@pacificcoastroasters.com'
  assign who_blocks         = section.blocks | where: 'type', 'who_card'
  assign benefit_blocks     = section.blocks | where: 'type', 'benefit'
  assign step_blocks        = section.blocks | where: 'type', 'step'
  assign product_blocks     = section.blocks | where: 'type', 'product_card'
  assign testimonial_blocks = section.blocks | where: 'type', 'testimonial'
  assign faq_blocks         = section.blocks | where: 'type', 'faq_item'
-%}

{%- comment -%}══ 1. HERO ══{%- endcomment -%}
<style>
  #ws-hero-{{ section.id }} {
    {%- if section.settings.hero_bg_color != blank and section.settings.hero_bg_color != 'rgba(0,0,0,0)' -%}
      background-color: {{ section.settings.hero_bg_color }};
    {%- endif -%}
  }
  #ws-hero-{{ section.id }} .pcr-ws-hero__overlay {
    background: {{ section.settings.hero_overlay_color | default: '#000000' }};
    opacity: {{ section.settings.hero_overlay_opacity | default: 65 | times: 0.01 }};
  }
</style>
<section id="ws-hero-{{ section.id }}" class="pcr-ws-hero">
  {%- if section.settings.hero_image != blank -%}
    <div class="pcr-ws-hero__bg" aria-hidden="true">
      <img
        src="{{ section.settings.hero_image | image_url: width: 1800 }}"
        srcset="{{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1400 }} 1400w, {{ section.settings.hero_image | image_url: width: 1800 }} 1800w"
        sizes="100vw"
        alt=""
        loading="eager"
        fetchpriority="high"
        class="pcr-ws-hero__bg-img"
      >
    </div>
  {%- endif -%}
  <div class="pcr-ws-hero__overlay" aria-hidden="true"></div>
  <div class="pcr-ws-hero__content page-width">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="pcr-ws-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    <h1 class="pcr-ws-hero__heading">{{ section.settings.hero_heading }}</h1>
    {%- if section.settings.hero_subheading != blank -%}
      <p class="pcr-ws-hero__subheading">{{ section.settings.hero_subheading }}</p>
    {%- endif -%}
    <div class="pcr-ws-hero__btns">
      {%- if section.settings.hero_btn1_label != blank -%}
        <a href="{{ section.settings.hero_btn1_url | default: '#ws-apply' }}" class="pcr-ws-btn pcr-ws-btn--gold">{{ section.settings.hero_btn1_label }}</a>
      {%- endif -%}
      {%- if section.settings.hero_btn2_label != blank -%}
        <a href="{{ section.settings.hero_btn2_url | default: '#ws-products' }}" class="pcr-ws-btn pcr-ws-btn--outline">{{ section.settings.hero_btn2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%}══ 3. VALUE PROPS ══{%- endcomment -%}
<section class="pcr-ws-section pcr-ws-value bg-stone">
  <div class="page-width">
    <div class="pcr-ws-value__layout">
      <div class="pcr-ws-value__copy">
        <h2 class="pcr-ws-section__title pcr-ws-section__title--left">{{ section.settings.value_title }}</h2>
        {%- if section.settings.value_lead != blank -%}
          <p class="pcr-ws-value__lead">{{ section.settings.value_lead }}</p>
        {%- endif -%}
        {%- if benefit_blocks.size > 0 -%}
          <div class="pcr-ws-value__benefits">
            {%- for block in benefit_blocks -%}
              <div class="pcr-ws-benefit" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <div class="pcr-ws-benefit__icon" aria-hidden="true">{{ block.settings.icon }}</div>
                {%- endif -%}
                <div>
                  <h4 class="pcr-ws-benefit__title">{{ block.settings.title }}</h4>
                  {%- if block.settings.description != blank -%}
                    <p class="pcr-ws-benefit__desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <div class="pcr-ws-value__image">
        {%- if section.settings.value_image != blank -%}
          <img
            src="{{ section.settings.value_image | image_url: width: 900 }}"
            srcset="{{ section.settings.value_image | image_url: width: 600 }} 600w, {{ section.settings.value_image | image_url: width: 900 }} 900w"
            sizes="(min-width: 1024px) 45vw, 100vw"
            alt="{{ section.settings.value_image.alt | default: 'Barista pouring coffee' | escape }}"
            loading="lazy"
            class="pcr-ws-value__img"
          >
        {%- else -%}
          <div class="pcr-ws-value__img-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- comment -%}══ 5. PRODUCTS ══{%- endcomment -%}
{%- if product_blocks.size > 0 -%}
<section id="ws-products" class="pcr-ws-section pcr-ws-products bg-black">
  <div class="page-width">
    <div class="pcr-ws-section__header">
      <h2 class="pcr-ws-section__title pcr-ws-section__title--white">{{ section.settings.products_title }}</h2>
      {%- if section.settings.products_subtitle != blank -%}
        <p class="pcr-ws-products__subtitle">{{ section.settings.products_subtitle }}</p>
      {%- endif -%}
    </div>
    <div class="pcr-ws-grid pcr-ws-grid--4">
      {%- for block in product_blocks -%}
        <div class="pcr-ws-product-card" {{ block.shopify_attributes }}>
          {%- if block.settings.use_label != blank -%}
            <span class="pcr-ws-product-card__use">{{ block.settings.use_label }}</span>
          {%- endif -%}
          <h3 class="pcr-ws-product-card__name">{{ block.settings.name }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="pcr-ws-product-card__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          <div class="pcr-ws-product-card__footer">
            <span class="pcr-ws-product-card__format-label">Available formats</span>
            <span class="pcr-ws-product-card__format">{{ block.settings.format }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
    <div class="pcr-ws-products__cta-wrap">
      <a href="#ws-apply" class="pcr-ws-btn pcr-ws-btn--ghost">
        {{ section.settings.products_catalog_label | default: 'Request Full Catalog →' }}
      </a>
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%}══ 7. TESTIMONIALS ══{%- endcomment -%}
{%- if testimonial_blocks.size > 0 -%}
<section class="pcr-ws-section pcr-ws-testimonials bg-stone-mid">
  <div class="page-width">
    <div class="pcr-ws-section__header">
      <h2 class="pcr-ws-section__title">{{ section.settings.testimonials_title }}</h2>
    </div>
    <div class="pcr-ws-grid pcr-ws-grid--2 pcr-ws-grid--max4xl">
      {%- for block in testimonial_blocks -%}
        <div class="pcr-ws-testimonial" {{ block.shopify_attributes }}>
          <div class="pcr-ws-testimonial__stars" aria-label="5 out of 5 stars">★★★★★</div>
          <blockquote class="pcr-ws-testimonial__quote">"{{ block.settings.quote }}"</blockquote>
          <footer class="pcr-ws-testimonial__author">
            <strong>{{ block.settings.author_name }}</strong>
            <span>{{ block.settings.author_title }}</span>
          </footer>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%}══ 8. FAQ ══{%- endcomment -%}
{%- if faq_blocks.size > 0 -%}
<section class="pcr-ws-section pcr-ws-faq bg-white">
  <div class="page-width pcr-ws-faq__inner">
    <h2 class="pcr-ws-section__title">{{ section.settings.faq_title }}</h2>
    {%- if section.settings.faq_description != blank -%}
      <p class="pcr-ws-section__subtitle">{{ section.settings.faq_description }}</p>
    {%- endif -%}
    <div class="pcr-ws-faq__list">
      {%- for block in faq_blocks -%}
        <details class="pcr-ws-faq__item" {{ block.shopify_attributes }}>
          <summary class="pcr-ws-faq__q">{{ block.settings.question }}</summary>
          <div class="pcr-ws-faq__a">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%}══ 9. CONTACT FORM ══{%- endcomment -%}
<section id="ws-apply" class="pcr-ws-section pcr-ws-form-section bg-black">
  <div class="page-width pcr-ws-form__inner">
    <div class="pcr-ws-section__header pcr-ws-section__header--white">
      <h2 class="pcr-ws-section__title pcr-ws-section__title--white">{{ section.settings.form_title }}</h2>
      {%- if section.settings.form_subtitle != blank -%}
        <p class="pcr-ws-form__subtitle">{{ section.settings.form_subtitle }}</p>
      {%- endif -%}
    </div>

    {%- if form.posted_successfully? -%}
      <div class="pcr-ws-form__success">
        <div class="pcr-ws-form__success-icon" aria-hidden="true">✓</div>
        <h3 class="pcr-ws-form__success-title">Application Received</h3>
        <p class="pcr-ws-form__success-desc">Thank you for reaching out. We're reviewing your details and will be in touch shortly.</p>
      </div>
    {%- else -%}
      {%- form 'contact', id: 'pcr-wholesale-form' -%}
        <div class="pcr-ws-form__card">
          {%- if form.errors -%}
            <div class="pcr-ws-form__errors" role="alert">
              Please fix the following errors:
              <ul>
                {%- for field in form.errors -%}
                  <li>{{ field }} — {{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="pcr-ws-form__row">
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-first-name">First Name</label>
              <input id="ws-first-name" type="text" name="contact[first_name]" required placeholder="Jane" class="pcr-ws-form__input">
            </div>
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-last-name">Last Name</label>
              <input id="ws-last-name" type="text" name="contact[last_name]" required placeholder="Doe" class="pcr-ws-form__input">
            </div>
          </div>

          <div class="pcr-ws-form__row">
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-business">Business Name</label>
              <input id="ws-business" type="text" name="contact[business_name]" required placeholder="The Daily Press" class="pcr-ws-form__input">
            </div>
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-type">Business Type</label>
              <select id="ws-type" name="contact[business_type]" class="pcr-ws-form__select">
                <option>Cafe / Coffee Shop</option>
                <option>Restaurant / Bar</option>
                <option>Office / Workplace</option>
                <option>Hotel / Hospitality</option>
                <option>Grocery / Retail</option>
                <option>Other</option>
              </select>
            </div>
          </div>

          <div class="pcr-ws-form__row">
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-email">Email Address</label>
              <input id="ws-email" type="email" name="contact[email]" required placeholder="jane@example.com" class="pcr-ws-form__input">
            </div>
            <div class="pcr-ws-form__field">
              <label class="pcr-ws-form__label" for="ws-volume">Estimated Weekly Volume</label>
              <select id="ws-volume" name="contact[weekly_volume]" class="pcr-ws-form__select">
                <option>Just starting out (under 10 lbs)</option>
                <option>10–30 lbs / week</option>
                <option>30–100 lbs / week</option>
                <option>100+ lbs / week</option>
              </select>
            </div>
          </div>

          <div class="pcr-ws-form__field">
            <label class="pcr-ws-form__label" for="ws-message">Tell us about your needs</label>
            <textarea id="ws-message" name="contact[body]" rows="4" class="pcr-ws-form__textarea" placeholder="Do you need equipment sourcing? Looking for a specific roast profile? Let us know."></textarea>
          </div>

          <button type="submit" class="pcr-ws-btn pcr-ws-btn--submit">Submit Inquiry</button>
          <p class="pcr-ws-form__note">Need immediate help? Email us at <a href="mailto:{{ contact_email }}" class="pcr-ws-form__note-link">{{ contact_email }}</a></p>
        </div>
      {%- endform -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PCR Wholesale",
  "tag": "section",
  "class": "pcr-section-wholesale",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Background image" },
    { "type": "color", "id": "hero_bg_color", "label": "Background color", "info": "Visible when no image is set." },
    { "type": "color", "id": "hero_overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "hero_overlay_opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 65 },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow text", "default": "Wholesale Partnership Program" },
    { "type": "text", "id": "hero_heading", "label": "Heading", "default": "Premium Small-Batch Coffee for Your Business" },
    { "type": "textarea", "id": "hero_subheading", "label": "Subheading", "default": "Freshly roasted to order in Watsonville, CA. Delivered fast, backed by real support. We make serving exceptional coffee simple." },
    { "type": "text", "id": "hero_btn1_label", "label": "Button 1 label", "default": "Apply for Wholesale" },
    { "type": "url", "id": "hero_btn1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "hero_btn2_label", "label": "Button 2 label", "default": "View Our Coffees" },
    { "type": "url", "id": "hero_btn2_url", "label": "Button 2 URL" },

    { "type": "header", "content": "Who It's For" },
    { "type": "text", "id": "who_title", "label": "Section title", "default": "Who We Partner With" },
    { "type": "textarea", "id": "who_subtitle", "label": "Subtitle", "default": "We build tailored coffee programs for businesses that care about quality and consistency." },

    { "type": "header", "content": "Value Props" },
    { "type": "text", "id": "value_title", "label": "Section title", "default": "More Than Just Coffee Beans" },
    { "type": "textarea", "id": "value_lead", "label": "Lead text", "default": "We know a successful coffee program requires reliability. That's why we focus on quality control, training, and making the ordering process completely stress-free for your team." },
    { "type": "image_picker", "id": "value_image", "label": "Side image (barista / pour shot)" },

    { "type": "header", "content": "Program Steps" },
    { "type": "text", "id": "steps_title", "label": "Section title", "default": "How the Program Works" },

    { "type": "header", "content": "Products" },
    { "type": "text", "id": "products_title", "label": "Section title", "default": "Core Wholesale Offerings" },
    { "type": "textarea", "id": "products_subtitle", "label": "Subtitle", "default": "Our full lineup. Every coffee ships with brew recipes and dial-in parameters." },
    { "type": "text", "id": "products_catalog_label", "label": "Catalog button label", "default": "Request Full Catalog →" },

    { "type": "header", "content": "Pricing" },
    { "type": "text", "id": "pricing_title", "label": "Panel title", "default": "Pricing & Volume Tiers" },
    { "type": "textarea", "id": "pricing_desc", "label": "Description", "default": "Our pricing is designed to grow alongside your business. Competitive margins for retail bags and volume discounts for bulk service." },
    { "type": "text", "id": "moq_label", "label": "Row 1 label", "default": "Standard MOQ" },
    { "type": "text", "id": "moq_value", "label": "Row 1 value", "default": "10 lbs / week" },
    { "type": "text", "id": "tier1_label", "label": "Row 2 label", "default": "Tier 1 Volume" },
    { "type": "text", "id": "tier1_value", "label": "Row 2 value", "default": "30+ lbs / week" },
    { "type": "text", "id": "tier2_label", "label": "Row 3 label", "default": "Tier 2 Volume" },
    { "type": "text", "id": "tier2_value", "label": "Row 3 value", "default": "100+ lbs / week" },
    { "type": "text", "id": "callout_title", "label": "Callout title", "default": "New Business Launch Kit" },
    { "type": "textarea", "id": "callout_desc", "label": "Callout description", "default": "Opening soon? Ask about our starter bundle — waived minimums for the first 30 days and priority on-site training included." },

    { "type": "header", "content": "Equipment & Training" },
    { "type": "text", "id": "equipment_title", "label": "Panel title", "default": "Equipment & Training" },
    { "type": "textarea", "id": "equipment_desc", "label": "Description", "default": "Great beans only go so far without the right gear and knowledge. We help with both." },
    { "type": "text", "id": "edu_icon", "label": "Education icon (emoji)", "default": "📚" },
    { "type": "text", "id": "edu_title", "label": "Education title", "default": "Education Program" },
    { "type": "textarea", "id": "edu_desc", "label": "Education description", "default": "Free quarterly training for your staff covering espresso fundamentals, milk science, and workflow optimization." },
    { "type": "text", "id": "equip_icon", "label": "Equipment sourcing icon (emoji)", "default": "🛠️" },
    { "type": "text", "id": "equip_title", "label": "Equipment sourcing title", "default": "Equipment Sourcing" },
    { "type": "textarea", "id": "equip_desc", "label": "Equipment sourcing description", "default": "We help source and recommend commercial equipment suited to your volume and budget, and provide ongoing maintenance guidance." },

    { "type": "header", "content": "Testimonials" },
    { "type": "text", "id": "testimonials_title", "label": "Section title", "default": "Trusted by Local Businesses" },

    { "type": "header", "content": "FAQ" },
    { "type": "text", "id": "faq_title", "label": "Section title", "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "faq_description", "label": "Section description" },

    { "type": "header", "content": "Contact Form" },
    { "type": "text", "id": "form_title", "label": "Section title", "default": "Start Your Wholesale Partnership" },
    { "type": "textarea", "id": "form_subtitle", "label": "Subtitle", "default": "Fill out the details below and our team will reach out within 24 hours to arrange a tasting." },
    { "type": "text", "id": "contact_email", "label": "Contact email", "default": "wholesale@pacificcoastroasters.com" }
  ],
  "blocks": [
    {
      "type": "who_card",
      "name": "Partner Type",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "☕" },
        { "type": "text", "id": "title", "label": "Title", "default": "Cafes & Bakeries" },
        { "type": "text", "id": "bullet_1", "label": "Bullet 1", "default": "Custom menu development and dial-in support" },
        { "type": "text", "id": "bullet_2", "label": "Bullet 2", "default": "On-site barista training and workflow optimization" },
        { "type": "text", "id": "bullet_3", "label": "Bullet 3", "default": "Whole bean and ground options in every roast level" }
      ]
    },
    {
      "type": "benefit",
      "name": "Value Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🚚" },
        { "type": "text", "id": "title", "label": "Title", "default": "Freshness Guaranteed" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Strict roast-to-order schedules. We roast weekly and ship within 48 hours to ensure every bag arrives at peak flavor." }
      ]
    },
    {
      "type": "step",
      "name": "Program Step",
      "settings": [
        { "type": "text", "id": "number", "label": "Step number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Inquire & Taste" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Fill out the form below. We'll send you a curated sample kit tailored to your equipment and volume needs." }
      ]
    },
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        { "type": "text", "id": "use_label", "label": "Use label", "default": "Espresso · Milk Drinks", "info": "e.g. Espresso · Milk Drinks" },
        { "type": "text", "id": "name", "label": "Product name", "default": "Mike's Blend" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Our flagship wholesale espresso. Rich dark chocolate, warm spice, and caramel sweetness. Cuts through milk perfectly — built for volume and consistency." },
        { "type": "text", "id": "format", "label": "Available formats", "default": "12oz & 1kg bags" }
      ]
    },
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote (no quotation marks needed)", "default": "Switching to Pacific Coast Roasters was the best operational decision we made this year." },
        { "type": "text", "id": "author_name", "label": "Author name", "default": "Sarah Jenkins" },
        { "type": "text", "id": "author_title", "label": "Author title & business", "default": "GM, The Daily Press Cafe — Santa Cruz, CA" }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your minimum order quantity?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Our standard wholesale minimum is 10 lbs per week. We offer flexible terms for new businesses during their launch phase — mention it in your inquiry and we'll work something out." }
      ]
    }
  ],
  "presets": [
    { "name": "PCR Wholesale" }
  ]
}
{% endschema %}
