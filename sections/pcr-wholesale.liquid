{% comment %}
  Pacific Coast Roasters — Wholesale Page Section
  Full-page marketing section for wholesale partner acquisition.
  Sections: hero → who it's for → value props → program steps →
            products → pricing/support → testimonials → FAQ → contact form
{% endcomment %}

{%- liquid
  assign contact_email = 'wholesale@pacificcoastroasters.com'
-%}

{%- comment -%} ══════════════════════════════════════════
  1. HERO
══════════════════════════════════════════ {%- endcomment -%}
<section class="pcr-ws-hero">
  {%- if section.settings.hero_image != blank -%}
    <div class="pcr-ws-hero__bg" aria-hidden="true">
      <img
        src="{{ section.settings.hero_image | image_url: width: 1800 }}"
        srcset="{{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1400 }} 1400w, {{ section.settings.hero_image | image_url: width: 1800 }} 1800w"
        sizes="100vw"
        alt=""
        loading="eager"
        fetchpriority="high"
        class="pcr-ws-hero__bg-img"
      >
    </div>
  {%- endif -%}
  <div class="pcr-ws-hero__overlay" aria-hidden="true"></div>
  <div class="pcr-ws-hero__content page-width">
    <p class="pcr-ws-hero__eyebrow">Wholesale Partnership Program</p>
    <h1 class="pcr-ws-hero__heading">{{ section.settings.hero_heading | default: 'Premium Small-Batch Coffee for Your Business' }}</h1>
    <p class="pcr-ws-hero__subheading">{{ section.settings.hero_subheading | default: 'Freshly roasted to order in Watsonville, CA. Delivered fast, backed by real support. We make serving exceptional coffee simple.' }}</p>
    <div class="pcr-ws-hero__btns">
      <a href="#ws-apply" class="pcr-ws-btn pcr-ws-btn--gold">Apply for Wholesale</a>
      <a href="#ws-products" class="pcr-ws-btn pcr-ws-btn--outline">View Our Coffees</a>
    </div>
  </div>
</section>

{%- comment -%} ══════════════════════════════════════════
  2. WHO IT'S FOR
══════════════════════════════════════════ {%- endcomment -%}
