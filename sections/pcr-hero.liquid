{% comment %}
  Pacific Coast Roasters — Custom Hero / Image Banner section
  Supports 3 buttons (Dawn's native Image Banner only supports 2).
  White content box centered over full-bleed background image — matches wireframe.

  Add to homepage via Theme Editor: Add Section → pcr-hero
  Place immediately after the Announcement Bar / Header.
{% endcomment %}


{%- liquid
  assign img          = section.settings.image
  assign gif_url      = section.settings.gif_url
  assign video_url    = section.settings.video_url
  assign height_class = section.settings.banner_height
-%}

<div class="pcr-hero pcr-hero--{{ height_class }}"
  {%- if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
    style="background-color: {{ section.settings.background_color }};"
  {%- endif -%}
>

  {%- comment -%} Background: video > GIF > static image {%- endcomment -%}
  {%- if video_url != blank -%}
    <div class="pcr-hero__bg" aria-hidden="true">
      <video
        class="pcr-hero__bg-img"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source src="{{ video_url }}" type="video/mp4">
      </video>
    </div>
  {%- elsif gif_url != blank -%}
    <div class="pcr-hero__bg" aria-hidden="true">
      <img
        src="{{ gif_url }}"
        alt="Hero background"
        loading="eager"
        class="pcr-hero__bg-img"
      >
    </div>
  {%- elsif img != blank -%}
    <div class="pcr-hero__bg" aria-hidden="true">
      <img
        src="{{ img | image_url: width: 1800 }}"
        srcset="
          {{ img | image_url: width: 750  }} 750w,
          {{ img | image_url: width: 1100 }} 1100w,
          {{ img | image_url: width: 1500 }} 1500w,
          {{ img | image_url: width: 1800 }} 1800w
        "
        sizes="100vw"
        alt="{{ img.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ img.width }}"
        height="{{ img.height }}"
        class="pcr-hero__bg-img"
      >
    </div>
  {%- else -%}
    <div class="pcr-hero__bg pcr-hero__bg--placeholder" aria-hidden="true"></div>
  {%- endif -%}

  {%- comment -%} Color overlay {%- endcomment -%}
  {%- if section.settings.overlay_opacity > 0 -%}
    {%- assign overlay_color = section.settings.overlay_color | default: '#000000' -%}
    <div class="pcr-hero__overlay" aria-hidden="true"
      style="position:absolute;inset:0;z-index:1;background:{{ overlay_color }};opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};pointer-events:none;"
    ></div>
  {%- endif -%}

  {%- comment -%} White content box {%- endcomment -%}
  <div class="pcr-hero__content-wrap page-width">
    <div class="pcr-hero__box">

      {%- if section.settings.eyebrow != blank -%}
        <p class="pcr-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="pcr-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="pcr-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- comment -%} 3 buttons {%- endcomment -%}
      {%- liquid
        assign has_btn1 = false
        assign has_btn2 = false
        assign has_btn3 = false
        if section.settings.btn1_label != blank and section.settings.btn1_url != blank
          assign has_btn1 = true
        endif
        if section.settings.btn2_label != blank and section.settings.btn2_url != blank
          assign has_btn2 = true
        endif
        if section.settings.btn3_label != blank and section.settings.btn3_url != blank
          assign has_btn3 = true
        endif
      -%}

      {%- if has_btn1 or has_btn2 or has_btn3 -%}
        <div class="pcr-hero__buttons">
          {%- if has_btn1 -%}
            <a href="{{ section.settings.btn1_url }}" class="button button--primary">
              {{ section.settings.btn1_label }}
            </a>
          {%- endif -%}
          {%- if has_btn2 -%}
            <a href="{{ section.settings.btn2_url }}" class="button button--outline">
              {{ section.settings.btn2_label }}
            </a>
          {%- endif -%}
          {%- if has_btn3 -%}
            <a href="{{ section.settings.btn3_url }}" class="button button--secondary">
              {{ section.settings.btn3_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

</div>

{% schema %}
{
  "name": "PCR Hero",
  "tag": "section",
  "class": "pcr-section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Background media (video takes priority, then GIF, then image)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background video URL (MP4)",
      "info": "Upload an MP4 to Shopify Admin → Content → Files, then paste the URL here. Video will autoplay, loop, and be muted."
    },
    {
      "type": "text",
      "id": "gif_url",
      "label": "Background GIF URL",
      "info": "Upload a GIF to Shopify Admin → Content → Files, then paste the URL here. Used only if no video URL is set."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (static fallback)",
      "info": "Recommended: 1800×900px or wider. Used only if no video or GIF URL is set."
    },
    {
      "type": "header",
      "content": "Colors & overlay"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "info": "Visible when no media is set, or behind transparent areas."
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000",
      "info": "Color layer drawn on top of background media."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 0
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner height",
      "options": [
        { "value": "small",  "label": "Small  (400px mobile / 480px desktop)" },
        { "value": "medium", "label": "Medium (500px mobile / 600px desktop)" },
        { "value": "large",  "label": "Large  (600px mobile / 720px desktop)" }
      ],
      "default": "medium"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Small-Batch Coffee, Direct-to-your-door"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Roasted fresh daily in Watsonville, California. Brewed every Saturday at Saratoga Farmers' Market."
    },
    {
      "type": "header",
      "content": "Button 1 — Primary (black)"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Label",
      "default": "Shop Best Sellers"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "URL",
      "info": "e.g. /collections/best-sellers"
    },
    {
      "type": "header",
      "content": "Button 2 — Outline"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Label",
      "default": "Shop Exotics"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "URL",
      "info": "e.g. /collections/exotics"
    },
    {
      "type": "header",
      "content": "Button 3 — Secondary (gold)"
    },
    {
      "type": "text",
      "id": "btn3_label",
      "label": "Label",
      "default": "Coffee Subscriptions"
    },
    {
      "type": "url",
      "id": "btn3_url",
      "label": "URL",
      "info": "e.g. /products/tour-de-coast-subscription"
    }
  ],
  "presets": [
    {
      "name": "PCR Hero"
    }
  ]
}
{% endschema %}
