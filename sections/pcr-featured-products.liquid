{% comment %}
  Pacific Coast Roasters — Featured Products section
  Renders 3 product cards + a hardcoded black Subscription CTA as the 4th slot.

  Uses Dawn's native card-product snippet for the 3 products so
  all built-in behaviors (quick add, lazy-load, hover image) work normally.

  Add to homepage via Theme Editor: Add Section → pcr-featured-products
  (replaces / supplements the built-in Featured Collection section)

  Grid: 1 col mobile → 2 col tablet (640px) → 4 col desktop (1024px)
{% endcomment %}


{%- liquid
  assign collection = collections[section.settings.collection]
  assign product_limit = 3
-%}

<div class="pcr-featured color-background-1 isolate">
  <div class="pcr-featured__inner page-width">

    {%- comment -%} Section header: heading left, "View Catalog" right {%- endcomment -%}
    <div class="pcr-featured-header">
      <div class="pcr-featured-header__text">
        <h2 class="pcr-featured-header__heading">
          {{ section.settings.heading | default: 'Small batch, third wave coffee sourced responsibly from hand-picked farmers all around the world.' }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="pcr-featured-header__desc">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank and collection != blank -%}
        <a href="{{ collection.url }}" class="pcr-featured-header__link">
          {{ section.settings.view_all_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} 4-column grid: 3 product cards + subscription CTA {%- endcomment -%}
    <ul class="pcr-featured__grid list-unstyled" role="list">

      {%- if collection != blank and collection.products.size > 0 -%}
        {%- assign popular_product = all_products[section.settings.popular_product] -%}
        {%- for product in collection.products limit: product_limit -%}
          {%- assign card_badge = blank -%}
          {%- if popular_product != blank and product.id == popular_product.id -%}
            {%- assign card_badge = section.settings.popular_label -%}
          {%- endif -%}
          <li class="pcr-featured__item">
            {% render 'pcr-card-product', card_product: product, badge: card_badge %}
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder cards when no collection is set or collection is empty {%- endcomment -%}
        {%- for i in (1..product_limit) -%}
          <li class="pcr-featured__item">
            <div class="card card--placeholder border border-black">
              <div class="card__inner" style="aspect-ratio: 1; background: #f3f4f6; display:flex; align-items:center; justify-content:center;">
                <span style="font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#9ca3af;">Product {{ i }}</span>
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} 4th slot: Subscription CTA card {%- endcomment -%}
      {%- if section.settings.show_sub_card == false -%}{%- assign skip_sub = true -%}{%- endif -%}
      {%- unless skip_sub -%}
      <li class="pcr-featured__item">
        <div class="pcr-sub-card">
          <svg class="pcr-sub-card__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
            <line x1="6" x2="6" y1="2" y2="4"/>
            <line x1="10" x2="10" y1="2" y2="4"/>
            <line x1="14" x2="14" y1="2" y2="4"/>
          </svg>

          <h3 class="pcr-sub-card__title">
            {{ section.settings.sub_title | default: 'Tour De Coast Coffee Subscription' }}
          </h3>

          <p class="pcr-sub-card__desc">
            {{ section.settings.sub_description | default: "Let us pick our favorite seasonal single origins for you every month. Save 15%." }}
          </p>

          {%- if section.settings.sub_url != blank -%}
            <a href="{{ section.settings.sub_url }}" class="pcr-sub-card__btn">
              {{ section.settings.sub_cta | default: 'Subscribe Now' }}
            </a>
          {%- endif -%}
        </div>
      </li>
      {%- endunless -%}

    </ul>

  </div>
</div>

{% schema %}
{
  "name": "PCR Featured Products",
  "tag": "section",
  "class": "pcr-section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Small batch, third wave coffee sourced responsibly from hand-picked farmers all around the world."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fresh roasted and shipped within 48 hours."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select the Featured Products collection (3 products shown)."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "\"View all\" link label",
      "default": "View Catalog"
    },
    {
      "type": "header",
      "content": "Most popular badge"
    },
    {
      "type": "product",
      "id": "popular_product",
      "label": "Most popular product",
      "info": "This product will get a banner badge on its card."
    },
    {
      "type": "text",
      "id": "popular_label",
      "label": "Badge label",
      "default": "Most Popular"
    },
    {
      "type": "header",
      "content": "Subscription CTA card"
    },
    {
      "type": "checkbox",
      "id": "show_sub_card",
      "label": "Show subscription card",
      "default": true
    },
    {
      "type": "text",
      "id": "sub_title",
      "label": "Title",
      "default": "Tour De Coast Coffee Subscription"
    },
    {
      "type": "textarea",
      "id": "sub_description",
      "label": "Description",
      "default": "Let us pick our favorite seasonal single origins for you every month. Save 15%."
    },
    {
      "type": "url",
      "id": "sub_url",
      "label": "Subscription product URL"
    },
    {
      "type": "text",
      "id": "sub_cta",
      "label": "Button label",
      "default": "Subscribe Now"
    }
  ],
  "presets": [
    {
      "name": "PCR Featured Products"
    }
  ]
}
{% endschema %}
