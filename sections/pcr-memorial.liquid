{% comment %}
  Pacific Coast Roasters — Memorial / Brand Story section
  "In memory of a Pacific Coast coffee legend, Mike Gobel"

  Left column: auto-advancing image slider (5 slide blocks, set in Theme Editor).
  Right column: story copy + optional CTA.

  Add to homepage via Theme Editor: Add Section → pcr-memorial
{% endcomment %}

{%- assign slide_blocks = section.blocks | where: 'type', 'slide' -%}

<div class="pcr-memorial">
  <div class="pcr-memorial__inner page-width">

    {%- comment -%} Image slider column {%- endcomment -%}
    <div class="pcr-memorial__media">
      <div class="pcr-slider" id="memorial-slider-{{ section.id }}">
        <div class="pcr-slider__track" id="memorial-track-{{ section.id }}">
          {%- for block in slide_blocks -%}
            <div class="pcr-slider__slide" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 450 }} 450w,
                    {{ block.settings.image | image_url: width: 900 }} 900w
                  "
                  sizes="(min-width: 1024px) 45vw, 100vw"
                  alt="{{ block.settings.alt | default: block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  class="pcr-slider__img"
                >
              {%- else -%}
                <div class="pcr-memorial__thumbnail-placeholder">
                  <span class="pcr-memorial__placeholder-label">Photo {{ forloop.index }}</span>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}

          {%- if slide_blocks.size == 0 -%}
            <div class="pcr-slider__slide">
              <div class="pcr-memorial__thumbnail-placeholder">
                <span class="pcr-memorial__placeholder-label">Add slides in Theme Editor</span>
              </div>
            </div>
          {%- endif -%}
        </div>

        {%- if slide_blocks.size > 1 -%}
          <div class="pcr-slider__dots" role="tablist" aria-label="Slide navigation">
            {%- for block in slide_blocks -%}
              <button
                class="pcr-slider__dot{% if forloop.first %} is-active{% endif %}"
                role="tab"
                aria-label="Slide {{ forloop.index }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-index="{{ forloop.index0 }}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Story column {%- endcomment -%}
    <div class="pcr-memorial__content">
      <h2 class="pcr-memorial__heading">
        {{ section.settings.heading | default: 'In memory of a Pacific Coast coffee legend, Mike Gobel' }}
      </h2>

      <div class="pcr-memorial__body rte">
        {%- if section.settings.body != blank -%}
          {{ section.settings.body }}
        {%- else -%}
          <p>
            It all started in the early 2010s when Dave walked into Mike's Highway 9 coffee shop
            and the two hit it off instantly. What began as a friendship turned into a full-blown
            partnership, with the two buying a coffee roaster together and bonding over their love
            of the craft.
          </p>
          <p>
            Tragically, we lost Mike in 2024. Losing a friend and partner hit Dave hard, but it
            also sparked a deeper connection. This loss brought him closer to the Pacific Coast
            recovery community, and today he's a dedicated advocate for addiction and rehabilitation,
            keeping Mike's story alive along the way.
          </p>
          <p>
            10% of every bag of Mike's Blend goes straight to supporting the Pacific Coast recovery
            community — a small way of honoring the guy who inspired it all.
          </p>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="button button--secondary pcr-memorial__cta">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

<script>
(function () {
  var track  = document.getElementById('memorial-track-{{ section.id }}');
  var dots   = document.querySelectorAll('#memorial-slider-{{ section.id }} .pcr-slider__dot');
  if (!track || dots.length < 2) return;

  var total   = dots.length;
  var current = 0;
  var timer;

  function goTo(n) {
    current = (n + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function (d, i) {
      d.classList.toggle('is-active', i === current);
      d.setAttribute('aria-selected', i === current ? 'true' : 'false');
    });
  }

  function advance() { goTo(current + 1); }

  function startTimer() { timer = setInterval(advance, 4500); }
  function resetTimer()  { clearInterval(timer); startTimer(); }

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      goTo(parseInt(dot.dataset.index, 10));
      resetTimer();
    });
  });

  startTimer();
})();
</script>

{% schema %}
{
  "name": "PCR Memorial Story",
  "tag": "section",
  "class": "pcr-section-memorial",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "In memory of a Pacific Coast coffee legend, Mike Gobel"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Story body",
      "info": "Leave blank to use default Mike Gobel story copy."
    },
    {
      "type": "header",
      "content": "Optional CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Photo slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PCR Memorial Story",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
