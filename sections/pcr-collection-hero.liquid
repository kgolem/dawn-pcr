{% comment %}
  Pacific Coast Roasters — Collection Hero
  Renders at the top of all collection pages.
  Shows collection title, description, optional hero image, and product count.
  Schema settings allow per-collection customization via Theme Editor.
{% endcomment %}

{%- liquid
  assign col = collection
  assign has_image = false
  if section.settings.hero_image != blank
    assign has_image = true
  elsif col.image != blank
    assign has_image = true
  endif
-%}

<div class="pcr-col-hero{% if has_image %} pcr-col-hero--has-image{% endif %}"
  {%- if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
    style="background-color: {{ section.settings.background_color }};"
  {%- endif -%}
>

  {%- if has_image -%}
    <div class="pcr-col-hero__bg" aria-hidden="true">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1800 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1400 }} 1400w, {{ section.settings.hero_image | image_url: width: 1800 }} 1800w"
          sizes="100vw"
          alt="{{ section.settings.hero_image.alt | default: col.title | escape }}"
          loading="eager"
          fetchpriority="high"
          class="pcr-col-hero__bg-img"
        >
      {%- elsif col.image != blank -%}
        <img
          src="{{ col.image | image_url: width: 1800 }}"
          srcset="{{ col.image | image_url: width: 900 }} 900w, {{ col.image | image_url: width: 1400 }} 1400w, {{ col.image | image_url: width: 1800 }} 1800w"
          sizes="100vw"
          alt="{{ col.image.alt | default: col.title | escape }}"
          loading="eager"
          fetchpriority="high"
          class="pcr-col-hero__bg-img"
        >
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.settings.overlay_opacity > 0 -%}
    {%- assign overlay_color = section.settings.overlay_color | default: '#000000' -%}
    <div class="pcr-col-hero__overlay" aria-hidden="true"
      style="position:absolute;inset:0;z-index:1;background:{{ overlay_color }};opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};pointer-events:none;"
    ></div>
  {%- endif -%}

  <div class="pcr-col-hero__content page-width">
    <div class="pcr-col-hero__box{% unless has_image %} pcr-col-hero__box--no-image{% endunless %}">

      <h1 class="pcr-col-hero__title">
        {{- section.settings.heading | default: col.title -}}
      </h1>

      {%- liquid
        assign desc = section.settings.description
        if desc == blank
          assign desc = col.description
        endif
      -%}
      {%- if desc != blank -%}
        <div class="pcr-col-hero__desc rte">{{ desc }}</div>
      {%- endif -%}

      {%- comment -%} Optional CTA {%- endcomment -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="button button--secondary pcr-col-hero__cta">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}

    </div>
  </div>

</div>

{% schema %}
{
  "name": "PCR Collection Hero",
  "tag": "section",
  "class": "pcr-section-collection-hero",
  "settings": [
    {
      "type": "paragraph",
      "content": "Defaults to the collection's own image and description. Override here for custom content per collection."
    },
    {
      "type": "header",
      "content": "Colors & overlay"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "info": "Visible when no hero image is set, or behind transparent areas."
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000",
      "info": "Color layer drawn on top of the hero image."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 0
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Override hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Override heading",
      "info": "Leave blank to use collection title."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Override description",
      "info": "Leave blank to use collection description."
    },
    {
      "type": "header",
      "content": "Optional CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    { "name": "PCR Collection Hero" }
  ]
}
{% endschema %}
